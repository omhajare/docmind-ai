# Eval Dashboard Environment Variables
# Copy to .env — never commit .env

# Backend URL for API calls
# Local:      http://localhost:8000
# Production: https://your-backend.onrender.com
EVAL_BACKEND_URL=http://localhost:8000

# Admin password (must match backend ADMIN_PASSWORD)
ADMIN_PASSWORD=your_admin_password_here

# Gemini API key (needed for RAGAS evaluation — Gemini acts as the judge LLM)
GEMINI_API_KEY=your_gemini_api_key

# RAGAS pass/fail threshold (0.0 - 1.0)
EVAL_PASS_THRESHOLD=0.70
